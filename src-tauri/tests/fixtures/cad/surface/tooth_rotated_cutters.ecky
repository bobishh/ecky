(model
  (part body
    (build
      (shape base (box 48 18 8))
      (shape tooth2d
        (polygon
          ((-2 4)
           (-2 0)
           (-0.75 -2)
           (0.75 -2)
           (2 0)
           (2 4))))
      (shape tooth
        (rotate 90 0 0
          (extrude tooth2d 22 :symmetric #t)))
      (shape cutters
        (repeat-compound i 5
          (translate (+ -16 (* i 8)) 0 4
            (rotate 0 (* i 7.5) 0 tooth))))
      (result (cut base cutters)))))

(model
  (params
    (number gauge 26 :label "gauge")
    (number width 40 :label "width")
    (number height 12 :label "height")
    (number groove_width 6 :label "groove width")
    (number groove_depth 3 :label "groove depth")
    (number duplo_height_blocks 5 :label "duplo height blocks")
    (number flat_start 48 :label "flat start")
    (number ramp_length 192 :label "ramp length")
    (number flat_end 48 :label "flat end"))
  (part body
    (build
      (shape dz (* duplo_height_blocks 19.2))
      (shape L (+ flat_start ramp_length flat_end))
      (shape ramp_end (+ flat_start ramp_length))
      (shape x1 (+ flat_start (* ramp_length 0.2)))
      (shape x2 (+ flat_start (* ramp_length 0.4)))
      (shape x3 (+ flat_start (* ramp_length 0.6)))
      (shape x4 (+ flat_start (* ramp_length 0.8)))
      (shape z1 (* dz 0.0954915))
      (shape z2 (* dz 0.3454915))
      (shape z3 (* dz 0.6545085))
      (shape z4 (* dz 0.9045085))
      (shape top_w (+ groove_width 2))
      (shape bot_w (- groove_width 2))
      (shape body2d
        (polygon
          ((0 height)
           (flat_start height)
           (x1 (+ height z1))
           (x2 (+ height z2))
           (x3 (+ height z3))
           (x4 (+ height z4))
           (ramp_end (+ height dz))
           (L (+ height dz))
           (L dz)
           (ramp_end dz)
           (x4 z4)
           (x3 z3)
           (x2 z2)
           (x1 z1)
           (flat_start 0)
           (0 0))))
      (shape body
        (rotate 90 0 0
          (extrude body2d width :symmetric #t)))
      (shape groove_profile
        (rotate 0 -90 0
          (polygon
            (((- height groove_depth) (- (/ bot_w 2)))
             ((- height groove_depth) (/ bot_w 2))
             ((+ height 2) (/ top_w 2))
             ((+ height 2) (- (/ top_w 2)))))))
      (shape groove_path
        (path
          ((0 0 0)
           (flat_start 0 0)
           (x1 0 z1)
           (x2 0 z2)
           (x3 0 z3)
           (x4 0 z4)
           (ramp_end 0 dz)
           (L 0 dz))))
      (shape groove_left
        (translate 0 (/ gauge 2) 0
          (sweep groove_profile groove_path)))
      (shape groove_right
        (translate 0 (- (/ gauge 2)) 0
          (sweep groove_profile groove_path)))
      (result (cut body groove_left groove_right)))))

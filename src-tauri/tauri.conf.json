{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Ecky CAD",
  "version": "0.0.1",
  "identifier": "com.alcoholics-audacious.ecky-cad",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Ecky CAD",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**", "$RESOURCE/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../server/freecad_runner.py": "server/freecad_runner.py",
      "../model-runtime/cad_sdk.py": "model-runtime/cad_sdk.py",
      "../model-runtime/cad_framework_contract.md": "model-runtime/cad_framework_contract.md",
      "../templates/cache_pot_default.FCMacro": "templates/cache_pot_default.FCMacro",
      "../templates/mess.stl": "templates/mess.stl"
    },
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

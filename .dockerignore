# Keep the Kamal remote build context lean.
# The Dockerfile only needs: sites/landing, src/lib/genie, src/lib/docs,
# scripts/build_ecky_ir_book.ts, public/docs/ecky-ir.md,
# docs/books/ecky-ir/assets, Dockerfile, nginx.conf.

# Heavy build artifacts
src-tauri/target/
node_modules/
sites/landing/node_modules/
sites/landing/dist/
target/
dist/

# Tauri / Rust / native runtimes (not needed for static site)
src-tauri/
runtimes/
*.wasm

# Git / CI / editor
.git/
.github/
.vscode/
.idea/
.claude/
.svelte-kit/
.DS_Store
*.log

# E2E / test artifacts
e2e/
playwright-report/
test-results/

# Skills / agent docs
skills/
AGENTS.md
GEMINI.md

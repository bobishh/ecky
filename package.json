{
  "name": "ecky-cad",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "dev:web": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json && tsc --project tsconfig.node.json --noEmit",
    "generate:contracts": "cargo run --manifest-path src-tauri/Cargo.toml --bin export_contracts",
    "check:contracts": "npm run generate:contracts && git diff --exit-code -- src/lib/tauri/contracts.ts",
    "test:unit": "tsx --test src/lib/**/*.test.ts",
    "test:e2e": "playwright test",
    "start": "tsx server/index.ts"
  },
  "dependencies": {
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.12.2",
    "@codemirror/state": "^6.5.4",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.39.16",
    "@tauri-apps/api": "^2.5.0",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "codemirror": "^6.0.2",
    "dotenv": "^16.6.1",
    "execa": "^9.6.0",
    "express": "^4.21.2",
    "three": "^0.180.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tauri-apps/cli": "^2.5.0",
    "@types/express": "^5.0.6",
    "@types/node": "^24.7.2",
    "@types/three": "^0.183.1",
    "concurrently": "^9.2.1",
    "svelte": "^5.28.1",
    "svelte-check": "^4.4.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^6.3.5"
  }
}

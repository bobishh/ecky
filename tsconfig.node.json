{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowJs": false,
    "checkJs": false,
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": [
    "e2e/**/*.d.ts",
    "server/**/*.ts",
    "e2e/**/*.ts",
    "vite.config.ts",
    "playwright.config.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "src-tauri",
    "test-results"
  ]
}
